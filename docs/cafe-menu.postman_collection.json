{
  "info": {
    "name": "Cafe Menu API",
    "description": "Cafe menu management REST API (Next.js Route Handlers + SQLite). Set the `baseUrl` collection variable (defaults to http://localhost:3000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "menuId", "value": "1" },
    { "key": "categoryId", "value": "5" }
  ],
  "item": [
    {
      "name": "Menus",
      "item": [
        {
          "name": "List menus",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus"]
            }
          }
        },
        {
          "name": "List menus — filter by category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus?category=coffee",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus"],
              "query": [{ "key": "category", "value": "coffee" }]
            }
          }
        },
        {
          "name": "List menus — sort by price ascending",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus?sort=price&order=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus"],
              "query": [
                { "key": "sort", "value": "price" },
                { "key": "order", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "List menus — search + price range + pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus?search=라떼&minPrice=4000&maxPrice=6000&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus"],
              "query": [
                { "key": "search", "value": "라떼" },
                { "key": "minPrice", "value": "4000" },
                { "key": "maxPrice", "value": "6000" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create menu",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"콜드브루\",\n  \"description\": \"12시간 저온 추출 커피\",\n  \"price\": 5500,\n  \"category\": \"coffee\",\n  \"imageUrl\": \"https://picsum.photos/seed/coldbrew/400/300\",\n  \"isAvailable\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menus",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus"]
            }
          }
        },
        {
          "name": "Get menu by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus/{{menuId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus", "{{menuId}}"]
            }
          }
        },
        {
          "name": "Update menu (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 5200,\n  \"description\": \"가격이 조정된 메뉴\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menus/{{menuId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus", "{{menuId}}"]
            }
          }
        },
        {
          "name": "Toggle availability (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menus/{{menuId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus", "{{menuId}}"]
            }
          }
        },
        {
          "name": "Delete menu",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus/{{menuId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus", "{{menuId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Menu statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menus", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            }
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"smoothie\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            }
          }
        },
        {
          "name": "Delete category (409 if in use)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    }
  ]
}
